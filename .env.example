# DocBot v3 — API Key Template
# Copy this file to .env and fill in your actual keys.
# NEVER commit .env to version control.
#
# ⚠️  SECURITY NOTICE: A previous version of this repository inadvertently
#    committed an Ollama API key. If you have access to the git history, you
#    should treat any keys visible there as compromised and rotate them
#    immediately via your provider's API dashboard.

# Anthropic (claude-sonnet-4-6 etc.)
ANTHROPIC_API_KEY=

# OpenAI-compatible endpoints (Groq, Together AI, etc.)
OPENAI_API_KEY=

# Ollama cloud endpoint
OLLAMA_API_KEY=
